# Optional API-Football / API-Sports key.
# Without this key, the project still works with free sources where available.
FOOTBALL_API_KEY=

# Service scheduler.
FOOTBALL_PREDICTOR_DB_PATH=
FOOTBALL_PREDICTOR_CACHE_DIR=
FOOTBALL_PREDICTOR_EXPORT_DIR=
FOOTBALL_PREDICTOR_ENABLE_SCHEDULER=true
FOOTBALL_PREDICTOR_TZ=Asia/Shanghai
FOOTBALL_PREDICTOR_UPDATE_HOUR=3
FOOTBALL_PREDICTOR_UPDATE_MINUTE=30

# Set true if the daily scheduler should also call API-Football.
# Keep false unless your API plan has enough quota.
FOOTBALL_PREDICTOR_DAILY_API_FOOTBALL=false

# Set true if the daily scheduler should also try FBref xG enrichment.
# FBref may rate-limit/403 some networks; keep false unless it works for you.
FOOTBALL_PREDICTOR_DAILY_FBREF_XG=false

# API-Football tuning.
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_TIMEOUT_S=45
API_FOOTBALL_MIN_INTERVAL_S=0.25
